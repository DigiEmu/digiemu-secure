{
  "name": "digiemu-secure",
  "version": "0.1.0",
  "description": "Cryptographic protection layer for DigiEmu Core evidence artifacts.",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "sign:example": "tsx src/sign-receipt.ts examples/secure-receipt.unsigned.example.json",
    "verify:example": "tsx src/verify-receipt.ts examples/secure-receipt.signed.example.json",
    "secure:verify": "node dist/cli.js verify",
    "secure:sign": "node dist/cli.js sign",
    "test:api": "tsx tests/api.test.ts",
    "test:cli": "npm run build && tsx tests/cli.test.ts"
  },
  "bin": {
    "secure": "./dist/cli.js"
  },
  "keywords": [
    "digiemu",
    "secure",
    "deterministic-ai",
    "verification",
    "cryptographic-evidence",
    "ed25519"
  ],
  "author": "Baumgartner Digital Infrastructure",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1"
  }
}
